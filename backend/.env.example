# LiveKit server (use ws:// for local, wss:// for cloud)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# OpenAI — used for STT (Whisper), TTS, and embeddings
OPENAI_API_KEY=sk-...

# Anthropic — used for the LLM (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the data directory (default: ./data)
# DATA_DIR=/path/to/data
